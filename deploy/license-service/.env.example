# Copy to ../../.env (repo root) and fill in. NEVER commit the real .env.
#
# Required: signs license keys and access cookies. Generate once and keep
# it stable (rotating it invalidates all issued keys/cookies):
#   openssl rand -hex 24
LICENSE_SECRET=

# Optional: enables automatic fulfillment on the post-payment redirect
# (POST /api/issue verifies the Stripe session is paid). Use your live key
# in production. Leave blank to use manual keygen + /api/activate only.
STRIPE_SECRET_KEY=

# Set to 1 in production (HTTPS) so the cookie is Secure. Leave 0 locally.
COOKIE_SECURE=1

# Optional cookie domain, e.g. .example.com (share across subdomains).
COOKIE_DOMAIN=

# Cookie / access lifetime in days. 3650 ≈ lifetime.
TOKEN_TTL_DAYS=3650
